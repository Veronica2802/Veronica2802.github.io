<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Veronica Akpatamu — VA Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy:   #0F1E3C;
    --gold:   #C9A84C;
    --cream:  #FAF8F4;
    --ink:    #1A1A2E;
    --muted:  #6B7280;
    --card:   #FFFFFF;
    --border: #E8E4DC;
    --gold-light: #F5EDD4;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--cream);
    color: var(--ink);
    line-height: 1.6;
  }

  /* ── HEADER ── */
  header {
    background: var(--navy);
    padding: 72px 24px 60px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  header::before {
    content: '';
    position: absolute;
    top: -60px; left: 50%;
    transform: translateX(-50%);
    width: 420px; height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,76,0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .badge {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(201,168,76,0.4);
    border-radius: 2px;
    padding: 5px 14px;
    margin-bottom: 24px;
  }

  header h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    color: #FFFFFF;
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  header h1 span {
    color: var(--gold);
    font-style: italic;
  }

  .header-sub {
    font-size: 15px;
    color: rgba(255,255,255,0.6);
    font-weight: 300;
    max-width: 460px;
    margin: 0 auto 32px;
  }

  .contact-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  .contact-chip {
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,0.75);
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 20px;
    padding: 6px 16px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .contact-chip:hover {
    background: rgba(201,168,76,0.2);
    color: var(--gold);
  }

  /* ── INTRO STRIP ── */
  .intro-strip {
    background: var(--gold);
    padding: 18px 24px;
    text-align: center;
  }
  .intro-strip p {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--navy);
    max-width: 680px;
    margin: 0 auto;
    letter-spacing: 0.01em;
  }

  /* ── MAIN ── */
  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 64px 24px 80px;
  }

  .section-label {
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* ── PORTFOLIO CARDS ── */
  .portfolio-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 64px;
  }

  @media (max-width: 600px) {
    .portfolio-grid { grid-template-columns: 1fr; }
  }

  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 28px 26px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: box-shadow 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 100%;
    background: var(--gold);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .card:hover {
    box-shadow: 0 8px 32px rgba(15,30,60,0.09);
    transform: translateY(-2px);
  }
  .card:hover::before { opacity: 1; }

  .card-icon {
    font-size: 22px;
    line-height: 1;
  }

  .card-tool {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
    background: var(--gold-light);
    display: inline-block;
    padding: 3px 10px;
    border-radius: 2px;
    width: fit-content;
  }

  .card h3 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.15rem;
    color: var(--navy);
    line-height: 1.25;
  }

  .card p {
    font-size: 13.5px;
    color: var(--muted);
    line-height: 1.65;
    flex: 1;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--navy);
    text-decoration: none;
    border-bottom: 1.5px solid var(--gold);
    padding-bottom: 1px;
    width: fit-content;
    margin-top: 4px;
    transition: color 0.2s;
  }
  .card-link:hover { color: var(--gold); }
  .card-link svg { transition: transform 0.2s; }
  .card-link:hover svg { transform: translateX(3px); }

  /* placeholder state */
  .card-link.placeholder {
    color: var(--muted);
    border-color: var(--border);
    cursor: default;
    pointer-events: none;
  }

  /* ── SKILLS ── */
  .skills-section { margin-bottom: 64px; }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .skill-pill {
    font-size: 12.5px;
    font-weight: 500;
    color: var(--navy);
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 7px 18px;
  }

  /* ── ABOUT ── */
  .about-section {
    background: var(--navy);
    border-radius: 4px;
    padding: 40px 36px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: center;
  }

  @media (max-width: 600px) {
    .about-section { grid-template-columns: 1fr; padding: 32px 24px; }
  }

  .about-section h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.7rem;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 12px;
  }
  .about-section h2 em {
    color: var(--gold);
    font-style: italic;
  }

  .about-section p {
    font-size: 13.5px;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .stat {
    border-left: 2px solid var(--gold);
    padding-left: 14px;
  }

  .stat-num {
    font-family: 'DM Serif Display', serif;
    font-size: 2rem;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: 11.5px;
    color: rgba(255,255,255,0.5);
    font-weight: 400;
  }

  /* ── FOOTER ── */
  footer {
    text-align: center;
    padding: 32px 24px;
    font-size: 12px;
    color: var(--muted);
    border-top: 1px solid var(--border);
  }
  footer a { color: var(--gold); text-decoration: none; }

  @media (prefers-reduced-motion: reduce) {
    .card { transition: none; }
  }
</style>
</head>
